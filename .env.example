# Copy to `.env` and fill. `.env` is gitignored.
# Payment-link URLs are public (same as on the live site); API keys and seeds are NOT.

# --- Square Payment Links (tiers, USD) — public URLs ---
SQUARE_PAY_USD_1=https://square.link/u/REPLACE_ME
SQUARE_PAY_USD_15=https://square.link/u/REPLACE_ME
SQUARE_PAY_USD_35=https://square.link/u/REPLACE_ME
SQUARE_PAY_USD_79=https://square.link/u/REPLACE_ME
SQUARE_PAY_USD_199=https://square.link/u/REPLACE_ME
# Donation: buyer chooses amount in Square
SQUARE_PAY_DONATION=https://square.link/u/REPLACE_ME

# --- Square API (fulfillment-bridge Worker / scripts only — never in static HTML) ---
# Used by Cloudflare Worker: fulfillment-bridge/README.md
# SQUARE_ACCESS_TOKEN= (wrangler secret put SQUARE_ACCESS_TOKEN)
# SQUARE_LOCATION_ID=
# SQUARE_ENVIRONMENT=production
# SQUARE_WEBHOOK_SIGNATURE_KEY= (wrangler secret put)
# SQUARE_WEBHOOK_NOTIFICATION_URL=https://<worker>/webhook  # exact URL from Square subscription
# RESEND_API_KEY= (wrangler secret put RESEND_API_KEY)
# FULFILL_FROM_EMAIL=fulfillment@yourdomain.com
# FULFILL_TO_OVERRIDE_EMAIL=  # optional test recipient override

# --- Other providers (examples) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Crypto (receive-only or xpub for gap-limit aware wallets; NEVER private keys) ---
# BTC_RECEIVE_ADDRESS=
# LNURL_OR_LIGHTNING_ADDRESS=

# --- Ads / analytics ---
# GOOGLE_ADS_CUSTOMER_ID=
# PLAUSIBLE_DOMAIN=
